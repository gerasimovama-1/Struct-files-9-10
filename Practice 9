}

void display_filtered(const char zagolovok[], films a[], int k)
{
    int i;
    cout << "\n" << zagolovok << "\n";
    cout << "Количество найденных фильмов: " << k << "\n\n";
    if (k == 0)
    {
        cout << "Данные не найдены.\n";
        return;
    }
    for (i = 0; i < k; i++)
    {
        display_film(a[i]);
    }
}

int copy_ryan()
{
    int i;
    int k = 0;
    for (i = 0; i < SIZE; i++)
    {
        if (!strcmp(film[i].actor, "Ryan_Gosling"))
        {
            RG[k] = film[i];
            k++;
        }
    }
    return k;
}

void sort_by_title(int k)
{
    int i, j;
    films temp;
    for (i = 0; i < k - 1; i++)
    {
        for (j = 0; j < k - 1 - i; j++)
        {
            if (strcmp(RG[j].title, RG[j + 1].title) > 0)
            {
                temp = RG[j];
                RG[j] = RG[j + 1];
                RG[j + 1] = temp;
            }
        }
    }
}

void find_film()
{
    int i;
    char name[60];
    cout << "Введите название фильма через _: ";
    cin >> name;
    for (i = 0; i < SIZE; i++)
    {
        if (!strcmp(name, film[i].title))
            break;
    }
    if (i == SIZE)
    {
        cout << "Фильм не найден.\n";
        return;
    }
    cout << "\nДанные по фильму:\n\n";
    display_film(film[i]);
}

int copy_expensive_2020s()
{
    int i;
    int k = 0;
    for (i = 0; i < SIZE; i++)
    {
        if (film[i].release >= 2020 && film[i].release <= 2029)
        {
            expensive[k] = film[i];
            k++;
        }
    }

    return k;
}

void sort_by_cost(int k)
{
    int i, j;
    films temp;
    for (i = 0; i < k - 1; i++)
    {
        for (j = 0; j < k - 1 - i; j++)
        {
            if (expensive[j].cost < expensive[j + 1].cost)
            {
                temp = expensive[j];
                expensive[j] = expensive[j + 1];
                expensive[j + 1] = temp;
            }
        }
    }
}

