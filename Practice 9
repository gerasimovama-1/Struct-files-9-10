void update()
{
    int i;
    char name[60];

    cout << "Введите название фильма, который нужно изменить: ";
    cin >> name;

    for (i = 0; i < SIZE; i++)
    {
        if (!strcmp(name, film[i].title))
            break;
    }

    if (i == SIZE)
    {
        cout << "Фильм не найден.\n";
        return;
    }

    cout << "Введите новую информацию о фильме.\n";
    input(i);

    cout << "Данные фильма изменены.\n";
}

int copy_david_thrillers()
{
    int i;
    int k = 0;

    for (i = 0; i < SIZE; i++)
    {
        if (!strcmp(film[i].type_fl, "thriller") &&
            !strncmp(film[i].director, "David_", 6))
        {
            david_thrillers[k] = film[i];
            k++;
        }
    }

    return k;
}

