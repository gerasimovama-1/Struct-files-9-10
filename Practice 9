    list_of_films();

    k_ryan = copy_ryan();
    sort_by_title(k_ryan);
    display_filtered("Фильмы с Райаном Гослингом по алфавиту", RG, k_ryan);

    find_film();

    k_expensive = copy_expensive_2020s();
    sort_by_cost(k_expensive);

    if (k_expensive > 4)
        k_expensive = 4;

    display_filtered("4 самых дорогих фильма 2020-х годов", expensive, k_expensive);

    update();

    k_david = copy_david_thrillers();
    display_filtered("Триллеры, где режиссера зовут David", david_thrillers, k_david);

    return 0;
}
