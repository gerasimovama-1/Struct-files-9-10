void display_film(films f)
{
    cout << "Название: " << f.title << "\n";
    cout << "Режиссер: " << f.director << "\n";
    cout << "Тип фильма: " << f.type_fl << "\n";
    cout << "Год выпуска: " << f.release << "\n";
    cout << "Длительность: " << f.duration << "\n";
    cout << "Стоимость создания: " << f.cost << "\n";
    cout << "Рейтинг: " << f.rating << "\n";
    cout << "Главный актер: " << f.actor << "\n\n";
}

void display_array(films a[], int k)
{
    int i;

    for (i = 0; i < k; i++)
    {
        display_film(a[i]);
    }
}

void create_text_file()
{
    ofstream fout;

    fout.open("ratings.txt");

    fout << "Drive " << 8.1 << "\n";
    fout << "Barbie " << 7.0 << "\n";
    fout << "Tenet " << 7.5 << "\n";
    fout << "Dune " << 8.2 << "\n";
    fout << "Oppenheimer " << 8.6 << "\n";

    fout.close();
}

void read_rating_from_text_file()
{
    ifstream fin;
    char name[60];
    double new_rating;
    int i;

    fin.open("ratings.txt");

    if (!fin.is_open())
    {
        cout << "Файл ratings.txt не открыт.\n";
        return;
    }

    while (fin >> name >> new_rating)
    {
        for (i = 0; i < SIZE; i++)
        {
            if (!strcmp(name, film[i].title))
            {
                film[i].rating = new_rating;
            }
        }
    }

    fin.close();
}

void write_binary_file()
{
    ofstream fout;

    fout.open("films.dat", ios::binary | ios::out);

    if (!fout.is_open())
    {
        cout << "Бинарный файл для записи не открыт.\n";
        return;
    }

    fout.write((char*)film, sizeof(film));

    fout.close();
}

void read_binary_file()
{
    ifstream fin;

    fin.open("films.dat", ios::binary | ios::in);

    if (!fin.is_open())
    {
        cout << "Бинарный файл для чтения не открыт.\n";
        return;
    }

    fin.read((char*)film_from_file, sizeof(film_from_file));

    fin.close();
}

int main()
{
    setlocale(LC_ALL, "Russian");

    list_of_films();

    cout << "Исходный массив фильмов:\n\n";
    display_array(film, SIZE);

    create_text_file();

    read_rating_from_text_file();

    cout << "\nМассив после чтения рейтингов из текстового файла:\n\n";
    display_array(film, SIZE);

    write_binary_file();

    read_binary_file();

    cout << "\nМассив, считанный из бинарного файла:\n\n";
    display_array(film_from_file, SIZE);

    return 0;
}
